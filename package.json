{
  "name": "logic-machine",
  "version": "2.0.0",
  "description": "A small, dependency-free logic evaluator for JavaScript.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --experimental-vm-modules --no-warnings=ExperimentalWarning node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules --no-warnings=ExperimentalWarning node_modules/jest/bin/jest.js --coverage",
    "build": "rolldown -c",
    "format": "prettier --write \"src/**/*.{js,d.ts}\"",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "logic",
    "machine",
    "rules",
    "rules-engine",
    "expression",
    "evaluator",
    "state",
    "automation",
    "finite"
  ],
  "author": "Alex Ivashkin <savegod1@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JWo1F/logic-machine.git"
  },
  "bugs": {
    "url": "https://github.com/JWo1F/logic-machine/issues"
  },
  "homepage": "https://github.com/JWo1F/logic-machine#readme",
  "sideEffects": false,
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rolldown": "^1.0.0-beta.1"
  }
}
